# ============================================
# RedDrop Backend - Environment Configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit the actual ".env" file to git.
# ============================================

# --- Server ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# --- MongoDB ---
# Local:      mongodb://127.0.0.1:27017/reddrop
# Atlas SRV:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/reddrop?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/reddrop

# --- Authentication (JWT) ---
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Cookie-based auth (if using httpOnly cookies instead of/along with localStorage)
JWT_COOKIE_EXPIRES_DAYS=7
COOKIE_SECURE=false
# set COOKIE_SECURE=true in production (requires HTTPS)

# --- Password Hashing ---
BCRYPT_SALT_ROUNDS=10

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Email (optional: password reset / notifications, e.g. via Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="RedDrop <no-reply@reddrop.app>"

# --- File Uploads (optional: profile pictures via Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Logging ---
LOG_LEVEL=dev
